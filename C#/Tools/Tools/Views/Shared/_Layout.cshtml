<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 光遇工具集</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tools.styles.css" asp-append-version="true" />
    <style>
        /* 自定义微调：可根据需要放入 site.css 中 */
        body {
            font-size: 16px;
            line-height: 1.6;
            background-color: #f8f9fa;
        }

        .navbar-dark .navbar-brand {
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .main-container {
            max-width: 1140px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        footer {
            background-color: #f8f9fa;
            border-top: 1px solid #e9ecef;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">🕊️ 光遇工具</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Wing" asp-action="Index">光翼查询</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cbg" asp-action="Index">藏宝阁估值</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 text-muted text-center small">
        <div class="container">
            &copy; @DateTime.Now.Year 光遇工具集 · 数据仅供参考
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>