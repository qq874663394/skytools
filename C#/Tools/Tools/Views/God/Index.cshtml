@{
    // Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>光遇账号估值 · 藏宝阁2026公式</title>
    <script src="https://cdn.bootcdn.net/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="~/js/data/game_auto_config.js"></script>
    <script src="~/js/data/packs_data.js"></script>
    <style type="text/css">
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        html {
            font-size: 16px
        }

        body {
            background: #70909f;
            font-family: 'Segoe UI','Noto Sans',system-ui,sans-serif;
            padding: 0.625em;
            color: #1f2e35
        }

        .container {
            max-width: 64em;
            margin: 0 auto;
            background: #fffcf6;
            border-radius: 1.5em;
            box-shadow: 0 0.75em 1.875em rgba(0,0,0,.15);
            padding: 1em 0.75em 1.25em;
            border: 0.0625em solid #e8dfd3;
            padding-bottom: 6em
        }

        h1 {
            font-size: 1.8em;
            font-weight: 500;
            text-align: center;
            color: #5e4632;
            margin-bottom: 0.375em;
            letter-spacing: 0.125em
        }

        .subtitle {
            text-align: center;
            color: #9b8c7c;
            margin-bottom: 1em;
            font-size: 0.85em;
            border-bottom: 0.0625em dashed #d9cdbc;
            padding-bottom: 0.625em
        }

        .tabs {
            display: flex;
            gap: 0;
            margin-bottom: 1em;
            flex-wrap: wrap
        }

        .tab-btn {
            flex: 1;
            min-width: 4em;
            padding: 0.5em 0.2em;
            border: none;
            background: #ede0d0;
            color: #5e4632;
            font-weight: 600;
            font-size: 0.75em;
            cursor: pointer;
            transition: .2s;
            border-radius: 0.75em 0.75em 0 0;
            border: 0.0625em solid #dacbb8
        }

            .tab-btn.active {
                background: #fdfaf5;
                border-bottom-color: #fdfaf5;
                color: #4e3b2c
            }

        .tab-content {
            display: none
        }

            .tab-content.active {
                display: block
            }

        .section {
            margin-bottom: 1em;
            background: #fdfaf5;
            border-radius: 1em;
            padding: 0.75em 0.625em;
            border: 0.0625em solid #ede3d6
        }

        .section-title {
            font-weight: 600;
            font-size: 0.9em;
            margin-bottom: 0.625em;
            display: flex;
            align-items: center;
            gap: 0.375em;
            color: #5a4a38
        }

        textarea {
            width: 100%;
            min-height: 4em;
            padding: 0.5em 0.75em;
            border-radius: 0.75em;
            border: 0.0625em solid #d6c8b6;
            font-size: 0.85em;
            font-family: monospace;
            resize: vertical
        }

        .btn {
            display: inline-block;
            padding: 0.5em 1.5em;
            background: #b48b5a;
            color: white;
            border: none;
            border-radius: 0.75em;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9em;
            text-align: center
        }

            .btn:hover {
                background: #9d7752
            }

        .btn-sm {
            padding: 0.3em 0.8em;
            font-size: 0.8em
        }

        .btn-block {
            display: block;
            width: 100%
        }

        .grid-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.625em
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.25em
        }

            .input-group label {
                font-size: 0.9em;
                font-weight: 500;
                color: #6b5e4c
            }

            .input-group input, .input-group select {
                padding: 0.5em 0.625em;
                border-radius: 0.75em;
                border: 0.0625em solid #d6c8b6;
                background: white;
                font-size: 0.9em;
                color: #3e3a35;
                outline: none
            }

        .season-actions {
            display: flex;
            gap: 0.5em;
            margin-bottom: 0.625em
        }

            .season-actions button {
                flex: 1;
                background: #c7b39b;
                color: white;
                border: none;
                padding: 0.375em 0;
                border-radius: 0.75em;
                font-size: 0.9em;
                cursor: pointer
            }

        .season-block {
            border: 0.0625em solid #e3d8c8;
            border-radius: 0.875em;
            margin-bottom: 0.375em;
            background: #fffdf9;
            overflow: hidden
        }

        .season-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.375em;
            padding: 0.5em 0.625em;
            cursor: pointer;
            user-select: none;
            background: #faf6ef
        }

            .season-header .season-name {
                font-weight: 600;
                font-size: 0.9em;
                color: #4e3b2c;
                display: flex;
                align-items: center;
                gap: 0.25em
            }

            .season-header .badge {
                background: #c7b39b;
                color: white;
                padding: 0.0625em 0.375em;
                border-radius: 0.625em;
                font-size: 0.8em;
                font-weight: 600
            }

            .season-header .arrow {
                font-size: 0.9em;
                color: #9b8c7c;
                transition: transform .2s
            }

            .season-header.expanded .arrow {
                transform: rotate(90deg)
            }

        .season-items {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5em;
            padding: 0.5em;
            background: #fffdf9
        }

        .season-header input[type="checkbox"] {
            width: 1em;
            height: 1em;
            accent-color: #b48b5a
        }

        .pack-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5em;
            max-height: 37.5em;
            overflow-y: auto;
            padding: 0.25em
        }

        .pack-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            background: #f6efe5;
            padding: 0.5em;
            border-radius: 0.875em;
            border: 0.0625em solid #ddd2c0;
            color: #3e3a35;
            text-align: center;
            transition: .2s;
            cursor: pointer;
            position: relative;
            width: 8em;
            min-height: 8em
        }

            .pack-card.selected {
                background: #e8dcc8;
                border-color: #b48b5a
            }

            .pack-card img {
                width: 4em;
                height: 4em;
                object-fit: contain;
                border-radius: 0.375em;
                background-color: #70909f;
                padding: 0.125em;
                margin-bottom: 0.375em
            }

            .pack-card .pack-name {
                font-weight: 500;
                font-size: 0.9em;
                word-break: break-word;
                line-height: 1.2
            }

            .pack-card .pack-price {
                font-weight: 600;
                font-size: 0.9em;
                color: #8b6914;
                margin-top: 0.25em
            }

            .pack-card input[type="checkbox"] {
                position: absolute;
                top: 0.25em;
                right: 0.25em;
                width: 1.2em;
                height: 1.2em;
                accent-color: #b48b5a;
                cursor: pointer;
                z-index: 2
            }

        .all-packs-wrap {
            max-height: 40em;
            overflow-y: auto
        }

        .all-packs-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 1em
        }

            .all-packs-table th {
                background: #f0e5d8;
                padding: 0.5em;
                text-align: center;
                font-weight: 600;
                border-bottom: 0.125em solid #d9cdbc;
                font-size: 1em;
                position: sticky;
                top: 0;
                z-index: 1
            }

            .all-packs-table td {
                padding: 0.5em;
                border-bottom: 0.0625em solid #ede3d6;
                vertical-align: middle;
                text-align: center;
                font-size: 1em
            }

            .all-packs-table .pack-icon-cell img {
                width: 4em;
                height: 4em;
                object-fit: contain;
                border-radius: 0.375em;
                background-color: #70909f;
                padding: 0.125em
            }

            .all-packs-table .pack-items-cell {
                text-align: left;
                font-size: 0.9em
            }

                .all-packs-table .pack-items-cell .sub-item {
                    display: inline-flex;
                    flex-direction: column;
                    align-items: center;
                    gap: 0.15em;
                    margin: 0.2em;
                    vertical-align: top
                }

                    .all-packs-table .pack-items-cell .sub-item img {
                        width: 4em;
                        height: 4em;
                        object-fit: contain;
                        border-radius: 0.3em;
                        background-color: #70909f;
                        padding: 0.1em
                    }

                    .all-packs-table .pack-items-cell .sub-item span {
                        font-size: 0.85em;
                        word-break: break-word;
                        max-width: 5em;
                        line-height: 1.15
                    }

        .tag-sm {
            display: inline-block;
            padding: 0.1em 0.4em;
            border-radius: 0.4em;
            font-size: 0.85em;
            font-weight: 600
        }

        .tag-top15 {
            background: #d5f5e3;
            color: #1e8449
        }

        .tag-new3 {
            background: #d6eaf8;
            color: #2471a3
        }

        .tag-no {
            color: #aaa
        }

        .summary-bar {
            background: #fff9f0;
            padding: 0.5em;
            border-radius: 0.75em;
            margin-bottom: 0.5em;
            font-size: 1em;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5em;
            justify-content: space-around;
            font-weight: 600
        }

        .history-list {
            max-height: 20em;
            overflow-y: auto
        }

        .history-item {
            padding: 0.5em;
            border-bottom: 0.0625em solid #ede3d6;
            cursor: pointer;
            font-size: 0.85em;
            transition: .2s;
            line-height: 1.5
        }

            .history-item:hover {
                background: #f6efe5
            }

            .history-item .hid {
                font-family: monospace;
                color: #8b7a68;
                font-size: 1em
            }

            .history-item .hres {
                font-size: 0.8em;
                color: #5f5344;
                margin-top: 0.15em
            }

        .floating-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(145deg,#f6efe5,#ede0d0);
            border-top: 0.125em solid #dacbb8;
            padding: 0.5em 0.75em;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5em;
            flex-wrap: wrap;
            box-shadow: 0 -0.25em 0.75em rgba(0,0,0,.1);
            font-size: 0.9em
        }

        .float-section {
            display: flex;
            align-items: center;
            gap: 0.25em
        }

        .float-label {
            font-weight: 600;
            color: #5e4632
        }

        .float-value {
            font-weight: 700;
            color: #4e3b2c
        }

        .float-total {
            font-size: 1.4em;
            font-weight: 700;
            color: #c0392b
        }

        .float-divider {
            width: 0.0625em;
            height: 1.5em;
            background: #d9cdbc;
            margin: 0 0.15em
        }

        .status {
            font-size: 0.85em;
            padding: 0.5em;
            border-radius: 0.75em;
            margin-top: 0.5em
        }

        .status-loading {
            background: #fef9e7;
            color: #7d6608
        }

        .status-ok {
            background: #d5f5e3;
            color: #1e8449
        }

        .status-err {
            background: #fce4d6;
            color: #c0392b
        }

        @@media(max-width:500px) {
            .pack-card {
                width: 6em;
                min-height: 6em
            }

                .pack-card img {
                    width: 4em;
                    height: 4em
                }

            .grid-2col {
                grid-template-columns: 1fr
            }

            .floating-bar {
                font-size: 0.8em
            }

            .float-total {
                font-size: 1.2em
            }

            .all-packs-table {
                font-size: 0.8em
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>✨ 光遇账号估值</h1>
        <div class="subtitle">藏宝阁2026估价公式 · 有翼版</div>
        <div class="tabs">
            <button class="tab-btn active" data-tab="tab-import">📥 导入</button>
            <button class="tab-btn" data-tab="tab1">📊 估值</button>
            <button class="tab-btn" data-tab="tab-all">📦 全部礼包</button>
        </div>

        <div class="tab-content active" id="tab-import">
            <div class="section">
                <div class="section-title">📥 粘贴藏宝阁链接</div>
                <textarea id="batchUrls"></textarea>
                <button class="btn btn-block" id="fetchBtn" style="margin-top:0.5em">🚀 获取并带入估值</button>
                <div id="importStatus"></div>
            </div>
            <div class="section" id="historySection" style="display:none">
                <div class="section-title">🕒 最近导入</div>
                <div class="history-list" id="historyList"></div>
            </div>
        </div>

        <div class="tab-content" id="tab1">
            <div class="section">
                <div class="section-title">📋 账号基础</div>
                <div class="grid-2col">
                    <div class="input-group"><label>区服</label><select id="regionSelect"><option>国服</option></select></div>
                    <div class="input-group"><label>系统</label><select id="osSelect"><option>iOS</option><option>安卓</option></select></div>
                    <div class="input-group"><label>渠道</label><select id="channelSelect"></select></div>
                    <div class="input-group"><label>绑定类型</label><select id="bindSelect"></select></div>
                    <div class="input-group"><label>光翼数量</label><input type="number" id="wingsInput" value="0"></div>
                    <div class="input-group"><label>蜡烛</label><input type="number" id="candlesInput" value="0"></div>
                    <div class="input-group"><label>爱心</label><input type="number" id="heartsInput" value="0"></div>
                    <div class="input-group"><label>升华蜡烛</label><input type="number" id="ascendedInput" value="0"></div>
                    <div class="input-group"><label>副卡数量</label><input type="number" id="subCardsInput" value="0"></div>
                    <div class="input-group"><label>身高值</label><input type="number" id="heightInput" step="0.01" value="0"></div>
                    <div class="input-group"><label>季节蜡烛</label><input type="number" id="scInput" value="0"></div>
                    <div class="input-group"><label>类型</label><select id="winglessSelect"><option value="0">有翼</option><option value="1">无翼</option></select></div>
                    <div class="input-group"><label>卖方价格</label><input type="number" id="sellerPriceInput" value="0"></div>
                </div>
            </div>
            <div class="section">
                <div class="section-title">🗓️ 毕业季节</div>
                <div class="season-actions"><button id="expandAllSeasons">全部展开</button><button id="collapseAllSeasons">全部折叠</button></div>
                <div id="seasonsContainer"></div>
            </div>
            <div class="section">
                <div class="section-title">🎁 礼包物品</div>
                <div class="pack-grid" id="packContainer"></div>
            </div>
        </div>

        <div class="tab-content" id="tab-all">
            <div class="section">
                <div class="section-title">📦 全部礼包清单</div>
                <div class="summary-bar" id="allPacksSummary"></div>
                <div class="all-packs-wrap">
                    <table class="all-packs-table" id="allPacksTable">
                        <thead><tr><th>图标</th><th>礼包名</th><th>热度</th><th>前15</th><th>新礼三</th><th>原价</th><th>系数</th><th>折后</th><th>包含物品</th></tr></thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="floating-bar" id="floatingBar">
        <div class="float-section"><span class="float-label">礼包原价</span><span class="float-value" id="floatPackOriginal">¥0</span></div>
        <div class="float-divider"></div>
        <div class="float-section"><span class="float-label">礼包折价</span><span class="float-value" id="floatPackValue">¥0</span></div>
        <div class="float-divider"></div>
        <div class="float-section"><span class="float-label">季节价值</span><span class="float-value" id="floatSeason">¥0</span></div>
        <div class="float-divider"></div>
        <div class="float-section"><span class="float-label">总价</span><span class="float-total" id="floatTotal">¥0</span></div>
        <div class="float-section"><span class="float-label">秒出</span><span class="float-value" id="floatQuick">¥0</span></div>
        <div class="float-section"><span class="float-label">难卖</span><span class="float-value" id="floatHard">¥0</span></div>
    </div>

    <script>
        $(function () {
            const itemsData = PACKS_DATA;
            let CONFIG = null;
            let seasonIdToName = {};
            let itemIdToSeasonId = {};
            let seasonOrder = [];
            let seasonGraduationMap = {};
            const HISTORY_KEY = 'sky_val_history';
            let currentImportData = null;

            function waitForConfig(cb) { if (typeof CBG_GAME_CONFIG !== 'undefined') { CONFIG = CBG_GAME_CONFIG; buildMaps(); cb(); } else setTimeout(() => waitForConfig(cb), 100); }
            function buildMaps() {
                if (!CONFIG) return;
                if (CONFIG.seasons) { CONFIG.seasons.forEach(s => { seasonIdToName[s.id] = s.name; }); seasonOrder = CONFIG.seasons.map(s => s.id).sort(); }
                if (CONFIG.filters) { CONFIG.filters.forEach(f => { if (f.season) itemIdToSeasonId[f.id] = f.season; if (f.season && f.id && !f.id.includes('Candle')) { if (!seasonGraduationMap[f.season]) seasonGraduationMap[f.season] = []; seasonGraduationMap[f.season].push(f.id); } }); }
            }
            function getItemName(id) {
                if (CONFIG?.outfit_from_cbg?.[id]?.names?.[0]) return CONFIG.outfit_from_cbg[id].names[0];
                if (CONFIG?.filters) { const f = CONFIG.filters.find(x => x.id === id); if (f?.name_str) return f.name_str; }
                if (CONFIG?.hot_appearance_from_cbg) { const h = CONFIG.hot_appearance_from_cbg.find(x => x.id === id); if (h?.name) return h.name; }
                return id.replace('CharSkyKid_', '');
            }
            function getItemImg(id) { if (!CONFIG?.display_content) return ''; const fn = CONFIG.display_content[id]; return fn ? 'https://cbg-sky.res.netease.com//game_res/' + fn : ''; }
            function isValuable(id) { return CONFIG?.valuable_appearance_from_cbg?.[id]; }
            function isHot(id) { return CONFIG?.hot_appearance_from_cbg?.some(h => h.id === id); }
            function getSeasonName(id) { const sid = itemIdToSeasonId[id]; return sid && seasonIdToName[sid] ? seasonIdToName[sid] : null; }

            const SPECIAL_SEASON_VALUES = { '感谢季羚羊面具': 6800, '追光季大伞': 7000, '归属季篝火': 3000, '音韵季白鸟发型': 8000, '颊纹三角面具': 0, '双边鬓饰': 1100, '包巾发型': 0 };
            const preFiveSeasons = ['感谢季', '追光季', '归属季', '音韵季', '魔法季'];

            function loadHistory() { try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch (e) { return []; } }
            function saveHistory(entry) {
                let hist = loadHistory();
                hist = hist.filter(h => h.id !== entry.id);
                hist.unshift(entry);
                if (hist.length > 20) hist = hist.slice(0, 20);
                localStorage.setItem(HISTORY_KEY, JSON.stringify(hist));
            }
            function buildHistoryEntry(id, url, data, sellerPrice) {
                const seasonNames = [];
                (data.season_graduation || []).forEach(gid => { const sn = getSeasonName(gid); if (sn && !seasonNames.includes(sn)) seasonNames.push(sn); });
                const highlights = [];
                (data.iap || []).forEach(iid => { const n = getItemName(iid); if (isValuable(iid) || isHot(iid)) { if (!highlights.includes(n)) highlights.push(n); } });
                return {
                    id, url,
                    candles: data.candles || 0, hearts: data.heart || 0, ascended: data.birth_buff || 0,
                    height: (data.equipped_outfit?.height || 0).toFixed(2),
                    sc: data.season_candles?.count || 0,
                    sellerPrice: sellerPrice || 0,
                    seasonStr: seasonNames.join('、') || '无',
                    highlightStr: highlights.join('、') || '无'
                };
            }
            function renderHistory() {
                const hist = loadHistory();
                console.log(hist)
                if (hist.length === 0) { $('#historySection').hide(); return; }
                $('#historySection').show();
                const $list = $('#historyList').empty();
                hist.forEach(h => {
                    const sellerStr = h.sellerPrice > 0 ? ` 卖方价：¥${h.sellerPrice}` : '';
                    const $item = $(`<div class="history-item" data-id="${h.id}">
                                                                <span class="hid">${h.id}</span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span>🕯${h.candles} ❤${h.hearts} 👼${h.ascended} 📏${h.height} 💫${h.sc}  ${sellerStr}</span>
                                                                <div class="hres">毕业季节：${h.seasonStr}</div>
                                                                <div class="hres">核心礼包：${h.highlightStr}</div>
                                                                <div class="hres">藏宝阁原文：<a href='${h.url}' target='_blank'>打开链接</a></div>
                                                            </div>`);
                    $item.on('click', function (e) {
                        if ($(e.target).is('a')) return; // 如果点击的是链接，不处理
                        $('#batchUrls').val(h.url);
                        $('#fetchBtn').click();
                    });
                    $list.append($item);
                });
            }

            $('.tab-btn').on('click', function () { const tab = $(this).data('tab'); $('.tab-btn').removeClass('active'); $('.tab-content').removeClass('active'); $(this).addClass('active'); $('#' + tab).addClass('active'); if (tab === 'tab-all') renderAllPacks(); });

            const $os = $('#osSelect'); const $ch = $('#channelSelect'); const $bi = $('#bindSelect');
            function updateChannels() { $ch.empty(); ($os.val() === 'iOS' ? ['官服'] : ['官服', '九游', '4399', '应用宝', '哔哩哔哩', 'vivo', '华为']).forEach(ch => { $ch.append(`<option value="${ch}">${ch}</option>`); }); updateBindings(); }
            function updateBindings() { $bi.empty(); if ($os.val() === 'iOS') { $bi.append('<option value="appleid">Apple ID</option>'); } else { ($ch.val() === '官服' ? ['手机号', '邮箱号'] : ['手机号']).forEach(b => { $bi.append(`<option value="${b}">${b}</option>`); }); } }
            $os.on('change', updateChannels); $ch.on('change', updateBindings); updateChannels();

            function renderSeasons(ownedGradIds = []) {
                $('#seasonsContainer').empty();
                const allSeasonIds = [...new Set(Object.values(itemIdToSeasonId))].sort((a, b) => seasonOrder.indexOf(a) - seasonOrder.indexOf(b));
                allSeasonIds.forEach(sid => {
                    const sname = seasonIdToName[sid] || sid;
                    const allItems = seasonGraduationMap[sid] || [];
                    if (allItems.length === 0) return;
                    const ownedInSeason = allItems.filter(id => ownedGradIds.includes(id));
                    const allOwned = ownedInSeason.length === allItems.length && allItems.length > 0;
                    const $block = $(`<div class="season-block" data-season="${sid}"></div>`);
                    const $header = $(`<div class="season-header"><div class="season-name"><input type="checkbox" class="season-all-check" data-season="${sid}" ${allOwned ? 'checked' : ''}><span>${sname}</span><span class="badge">${ownedInSeason.length}/${allItems.length}</span></div><span class="arrow">▶</span></div>`);
                    const $items = $(`<div class="season-items" style="display:none"></div>`);
                    allItems.forEach(id => {
                        const name = getItemName(id); const img = getItemImg(id); const has = ownedGradIds.includes(id);
                        const $card = $(`<div class="pack-card ${has ? 'selected' : ''}"><img src="${img || ''}" alt="${name}" onerror="this.style.display='none'"><span class="pack-name">${name}</span><input type="checkbox" data-season="${sid}" data-id="${id}" ${has ? 'checked' : ''}></div>`);
                        $card.on('click', function (e) { if (e.target.tagName !== 'INPUT') { const cb = $(this).find('input'); cb.prop('checked', !cb.prop('checked')); cb.trigger('change'); } });
                        $card.find('input').on('change', function () { const checked = $(this).prop('checked'); $card.toggleClass('selected', checked); updateSeasonAllCheck($block); updateFloat(); });
                        $items.append($card);
                    });
                    $block.append($header).append($items);
                    $header.on('click', function (e) { if (e.target.tagName === 'INPUT') return; $items.toggle(); $header.toggleClass('expanded', $items.is(':visible')); });
                    $header.find('.season-all-check').on('change', function () { const checked = $(this).prop('checked'); $items.find('input[type="checkbox"]').prop('checked', checked); $items.find('.pack-card').toggleClass('selected', checked); updateFloat(); });
                    $('#seasonsContainer').append($block);
                });
            }
            function updateSeasonAllCheck($block) { const $checks = $block.find('.season-items input[type="checkbox"]'); const all = $checks.length > 0 && Array.from($checks).every(c => c.checked); $block.find('.season-all-check').prop('checked', all); $block.find('.badge').text($checks.filter(':checked').length + '/' + $checks.length); }
            $('#expandAllSeasons').on('click', () => { $('.season-items').show(); $('.season-header').addClass('expanded'); });
            $('#collapseAllSeasons').on('click', () => { $('.season-items').hide(); $('.season-header').removeClass('expanded'); });

            const packToItemsMap = new Map(); const packInfoMap = new Map(); const configIdToPackIdx = new Map();
            itemsData.forEach((item, idx) => {
                if (!packToItemsMap.has(item.pack)) { packToItemsMap.set(item.pack, []); packInfoMap.set(item.pack, { price: item.price, heat: item.heat, top15: item.top15, newTop3: item.newTop3 }); }
                packToItemsMap.get(item.pack).push(idx);
                if (item.id) configIdToPackIdx.set(item.id, idx);
            });
            function calcPackValue(packName) { const info = packInfoMap.get(packName); if (!info) return 0; const rate = { '联动热门': 0.5, '热门': 0.3, '小礼': 0.2, '普通': 0.1 }[info.heat] || 0.1; return Math.round(info.price * rate); }
            function getPackRate(packName) { const info = packInfoMap.get(packName); if (!info) return 0.1; return { '联动热门': 0.5, '热门': 0.3, '小礼': 0.2, '普通': 0.1 }[info.heat] || 0.1; }

            function renderPacks(ownedIapIds = []) {
                $('#packContainer').empty();
                itemsData.forEach((item, idx) => {
                    const has = ownedIapIds.includes(item.id);
                    const $card = $(`<div class="pack-card ${has ? 'selected' : ''}" data-index="${idx}"><img src="${item.img}" alt="${item.name}" onerror="this.style.display='none'"><span class="pack-name">${item.name}</span><span class="pack-price">¥${item.price}</span><input type="checkbox" id="pack-${idx}" ${has ? 'checked' : ''}></div>`);
                    $card.on('click', function (e) { if (e.target.tagName !== 'INPUT') { const cb = $('#pack-' + idx); cb.prop('checked', !cb.prop('checked')); cb.trigger('change'); } });
                    $card.find('input').on('change', function () { const checked = $(this).prop('checked'); (packToItemsMap.get(item.pack) || []).forEach(i => { $('#pack-' + i).prop('checked', checked); $(`.pack-card[data-index="${i}"]`).toggleClass('selected', checked); }); $card.toggleClass('selected', checked); updateFloat(); });
                    $('#packContainer').append($card);
                });
            }

            function renderAllPacks() {
                const $tb = $('#allPacksTable tbody').empty(); const allPackNames = [...new Set(itemsData.map(i => i.pack))]; let totalOriginal = 0, totalDiscounted = 0, totalItems = 0;
                allPackNames.forEach(packName => {
                    const info = packInfoMap.get(packName) || { price: 0, heat: '普通', top15: false, newTop3: false }; const rate = getPackRate(packName); const discounted = calcPackValue(packName); const items = (packToItemsMap.get(packName) || []).map(i => itemsData[i]); const firstImg = items[0]?.img || ''; totalOriginal += info.price; totalDiscounted += discounted; totalItems += items.length;
                    const heatBadge = info.heat === '联动热门' ? '<span class="tag-sm" style="background:#fce4d6;color:#c0392b">联动热门</span>' : info.heat === '热门' ? '<span class="tag-sm" style="background:#fef9e7;color:#b7950b">热门</span>' : info.heat === '小礼' ? '<span class="tag-sm" style="background:#e5e7e9;color:#5d6d7e">小礼</span>' : '<span class="tag-sm" style="background:#e5e7e9;color:#5d6d7e">普通</span>';
                    $tb.append(`<tr><td class="pack-icon-cell"><img src="${firstImg}" alt="${packName}"></td><td><strong>${packName}</strong></td><td>${heatBadge}</td><td>${info.top15 ? '<span class="tag-sm tag-top15">✓</span>' : '<span class="tag-no">-</span>'}</td><td>${info.newTop3 ? '<span class="tag-sm tag-new3">✓</span>' : '<span class="tag-no">-</span>'}</td><td>¥${info.price}</td><td>${rate}</td><td><strong>¥${discounted}</strong></td><td class="pack-items-cell">${items.map(it => `<span class="sub-item"><img src="${it.img}" alt="${it.name}" onerror="this.style.display='none'"><span>${it.name}</span></span>`).join('')}</td></tr>`);
                });
                $('#allPacksSummary').html(`<span>📦 礼包总数: <strong>${allPackNames.length}</strong></span><span>📋 物品总数: <strong>${totalItems}</strong></span><span>💰 原价总额: <strong>¥${totalOriginal}</strong></span><span>💵 折算总额: <strong>¥${totalDiscounted}</strong></span>`);
            }

            function updateFloat() {
                let seasonTotal = 0, specialBonus = 0; const indices = [];
                $('.season-block').each(function () { const sid = $(this).data('season'); const sname = seasonIdToName[sid] || ''; const $checks = $(this).find('.season-items input[type="checkbox"]'); const any = $checks.is(':checked'); const all = $checks.length > 0 && Array.from($checks).every(c => c.checked); if (any) { indices.push(seasonOrder.indexOf(sid)); $checks.each(function () { const itemId = $(this).data('id'); const name = getItemName(itemId); if ($(this).prop('checked') && SPECIAL_SEASON_VALUES[name]) specialBonus += SPECIAL_SEASON_VALUES[name]; }); if (!preFiveSeasons.includes(sname)) seasonTotal += all ? 20 : 10; } });
                let coherence = 0; if (indices.length >= 8) { const sorted = [...indices].sort((a, b) => a - b); let max = 1, cur = 1; for (let i = 1; i < sorted.length; i++) { if (sorted[i] === sorted[i - 1] + 1) { cur++; if (cur > max) max = cur; } else cur = 1; } if (max >= 8) { const mult = Math.floor(max / 8); coherence = Math.round((seasonTotal + specialBonus) * mult * 0.1); if (indices.some(i => i < 5)) coherence = Math.round(coherence * 1.5); } }
                const totalSeason = seasonTotal + specialBonus + coherence;
                const selectedPacks = new Set(); $('#packContainer input:checked').each(function () { const idx = $(this).closest('.pack-card').data('index'); if (idx !== undefined) selectedPacks.add(itemsData[idx].pack); });
                let packOriginal = 0, packValue = 0; selectedPacks.forEach(pack => { const info = packInfoMap.get(pack); if (info) { packOriginal += info.price; packValue += calcPackValue(pack); } });
                let packBonus = selectedPacks.size >= 30 ? Math.floor((selectedPacks.size - 30) / 10) * 15 : 0; packValue += packBonus;
                const wings = parseInt($('#wingsInput').val()) || 0; let wingBonus = wings >= 130 ? 50 : wings >= 120 ? Math.max(0, 50 - Math.floor((130 - wings) / 10) * 10) : 0;
                const heightVal = parseFloat($('#heightInput').val()) || 0; let heightBonus = 0; if (heightVal >= 1.9) heightBonus = 80; else if (heightVal <= -1.9) heightBonus = 100; else if (Math.abs(heightVal) >= 1.5) heightBonus = 40;
                const total = totalSeason + packValue + wingBonus + heightBonus; let quick, hard; if (total <= 500) { quick = Math.round(total * 0.75); hard = total + 50; } else if (total <= 1000) { quick = Math.round(total * 0.7); hard = total; } else if (total <= 2000) { quick = Math.round(total * 0.75); hard = total - 100; } else { quick = Math.round(total * 0.85); hard = Math.round(total * 1.1); }
                $('#floatPackOriginal').text('¥' + packOriginal); $('#floatPackValue').text('¥' + packValue); $('#floatSeason').text('¥' + totalSeason); $('#floatTotal').text('¥' + total); $('#floatQuick').text('¥' + quick); $('#floatHard').text('¥' + hard);
            }
            $('#wingsInput,#heightInput,#sellerPriceInput').on('input', updateFloat);

            function extractId(url) { url = url.trim(); let m = url.match(/equip\/\d+\/([a-f0-9-]+)/); if (m) return m[1]; m = url.match(/equipdesc\/([a-f0-9-]+)\.json/); if (m) return m[1]; m = url.match(/^([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/); return m ? m[1] : null; }
            function getJsonUrl(id) { return 'https://cbg-other-desc.res.netease.com/sky/static/equipdesc/' + id + '.json'; }
            function parseEquip(wrapper) { if (!wrapper) return null; try { const equipDesc = typeof wrapper.equip_desc === 'string' ? JSON.parse(wrapper.equip_desc) : wrapper.equip_desc; let raw = equipDesc.raw_content; if (typeof raw === 'string') { raw = raw.replace(/\\"/g, '"').replace(/\\n/g, '\n'); if (raw.startsWith('"') && raw.endsWith('"')) raw = raw.slice(1, -1); raw = JSON.parse(raw); } return raw; } catch (e) { return null; } }

            $('#fetchBtn').on('click', async function () {
                const text = $('#batchUrls').val().trim(); if (!text) { $('#importStatus').html('<div class="status status-err">请输入链接</div>'); return; }
                const urls = text.split(/[\n\r]+/).filter(u => u.trim()); const $st = $('#importStatus').html('<div class="status status-loading">获取中...</div>');
                const id = extractId(urls[0]); if (!id) { $st.html('<div class="status status-err">无法提取ID</div>'); return; }
                try {
                    const r = await fetch(getJsonUrl(id)); if (!r.ok) throw new Error('HTTP ' + r.status);
                    const data = parseEquip(await r.json()); if (!data) throw new Error('解析失败');
                    currentImportData = { id, url: urls[0], data };
                    $('#candlesInput').val(data.candles || 0); $('#heartsInput').val(data.heart || 0); $('#ascendedInput').val(data.prestige || 0); $('#wingsInput').val(data.birth_buff || 0); $('#subCardsInput').val(data.season_pass_token || 0); $('#scInput').val(data.season_candles?.count || 0); $('#winglessSelect').val(data.is_wingless ? '1' : '0');
                    if (data.equipped_outfit?.height) $('#heightInput').val(data.equipped_outfit.height.toFixed(3));
                    const ownedGradIds = data.season_graduation || [];
                    const ownedIapIds = data.iap || [];
                    renderSeasons(ownedGradIds);
                    renderPacks(ownedIapIds);
                    updateFloat();
                    setTimeout(() => {
                        const sellerPrice = parseInt($('#sellerPriceInput').val()) || 0;
                        saveHistory(buildHistoryEntry(id, urls[0], data, sellerPrice));
                        renderHistory();
                        const seasonNames = [...new Set(ownedGradIds.map(gid => getSeasonName(gid)).filter(Boolean))];
                        const highlights = ownedIapIds.filter(iid => isValuable(iid) || isHot(iid)).map(iid => getItemName(iid)).filter((v, i, a) => a.indexOf(v) === i);
                        const sellerStr = sellerPrice > 0 ? ` 卖方价：¥${sellerPrice}` : '';
                        $st.html(`<div class="status status-ok">✅ 已带入估值页！<br><span style="font-size:0.8em">${id.substring(0, 8)}... 🕯${data.candles || 0} ❤${data.heart || 0} 👼${data.birth_buff || 0} 📏${(data.equipped_outfit?.height || 0).toFixed(2)} 💫${data.season_candles?.count || 0}${sellerStr}<br>毕业季节：${seasonNames.join('、') || '无'}<br>核心礼包：${highlights.join('、') || '无'}</span></div>`);
                    }, 100);
                    $('.tab-btn[data-tab="tab1"]').click();
                } catch (e) { $st.html(`<div class="status status-err">${e.message}</div>`); }
            });

            $('#sellerPriceInput').on('input', function () {
                if (currentImportData) {
                    const sellerPrice = parseInt($(this).val()) || 0;
                    saveHistory(buildHistoryEntry(currentImportData.id, currentImportData.url, currentImportData.data, sellerPrice));
                    renderHistory();
                }
            });

            waitForConfig(() => { renderSeasons(); renderPacks(); updateFloat(); renderHistory(); });
        });
    </script>
</body>
</html>
